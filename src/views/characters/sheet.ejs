<h1>Character Sheet</h1>

<section class="identity">
  <h2>Identity</h2>
  <div class="row"><label>Name</label><input type="text"></div>
  <div class="row"><label>Class</label><input type="text"></div>
  <div class="row"><label>Level</label><input type="number"></div>
  <div class="row"><label>Background</label><input type="text"></div>
</section>

<section class="stats">
  <h2>Core Stats</h2>
  <div class="stat-grid">
    <div><label>STR</label><input type="number"></div>
    <div><label>DEX</label><input type="number"></div>
    <div><label>CON</label><input type="number"></div>
    <div><label>INT</label><input type="number"></div>
    <div><label>WIS</label><input type="number"></div>
    <div><label>CHA</label><input type="number"></div>
  </div>
</section>

<section class="combat">
  <h2>Combat</h2>
  <div class="row"><label>HP</label><input type="text"></div>
  <div class="row"><label>AC</label><input type="number"></div>
  <div class="row"><label>Initiative</label><input type="text"></div>
  <div class="row"><label>Speed</label><input type="text"></div>
</section>

<section class="skills">
  <h2>Skills</h2>

  <div id="skills-container">

    <% const dndSkills = [
      "Acrobatics", "Animal Handling", "Arcana", "Athletics",
      "Deception", "History", "Insight", "Intimidation",
      "Investigation", "Medicine", "Nature", "Perception",
      "Performance", "Persuasion", "Religion", "Sleight of Hand",
      "Stealth", "Survival"
    ]; %>

    <% dndSkills.forEach(skill => { %>
      <div class="skill-block" id="<%= skill %>">
        <h3><%= skill %></h3>

        <div class="subskills"></div>

        <div class="row">
          <input type="text" class="subskill-name" placeholder="Sub-skill name">
          <input type="number" class="subskill-value" placeholder="Bonus">
          <button onclick="addSubSkill('<%= skill %>')">Add</button>
        </div>
      </div>
    <% }) %>

  </div>
</section>


<div class="sheet-container">
  <section class="features sheet-section">
    <h2>Features & Traits</h2>
    <textarea class="sheet-box" rows="6"></textarea>
  </section>

  <section class="inventory sheet-section">
    <h2>Inventory</h2>
    <textarea class="sheet-box" rows="6"></textarea>
  </section>
</div>

<script>
  function addSubSkill(skillName) {
    const block = document.getElementById(skillName);
    const nameInput = block.querySelector(".subskill-name");
    const valueInput = block.querySelector(".subskill-value");

    const name = nameInput.value.trim();
    const value = valueInput.value.trim();

    if (!name) return;

    const container = block.querySelector(".subskills");
    const div = document.createElement("div");
    div.className = "skill";
    div.innerHTML = `<span>${name}</span><input type="number" value="${value || ''}">`;
    container.appendChild(div);

    nameInput.value = "";
    valueInput.value = "";
  }
</script>

<form id="autosave-form" action="/characters/sheet/save" method="POST">
  <input type="hidden" name="name">
  <input type="hidden" name="className">
  <input type="hidden" name="level">
  <textarea name="stats" id="stats-json" hidden></textarea>
</form>

<script>
  function gatherSheetData() {
    const data = {};

    data.name = document.querySelector('.identity input:nth-child(2)').value;
    data.className = document.querySelector('.identity input:nth-child(4)').value;
    data.level = document.querySelector('.identity input:nth-child(6)').value;


    const stats = {};
    document.querySelectorAll('.stat-grid input').forEach((input, i) => {
      const keys = ["str", "dex", "con", "int", "wis", "cha"];
      stats[keys[i]] = Number(input.value || 0);
    });


    const skillData = {};
    document.querySelectorAll('.skill-block').forEach(block => {
      const skillName = block.id;
      const subskills = [];

      block.querySelectorAll('.subskills .skill').forEach(sub => {
        const name = sub.querySelector('span').innerText;
        const value = Number(sub.querySelector('input').value || 0);
        subskills.push({ name, value });
      });

      skillData[skillName] = subskills;
    });

    data.features = document.querySelector('.features textarea').value;
    data.inventory = document.querySelector('.inventory textarea').value;


    data.stats = {
      ...stats,
      skills: skillData,
      features: data.features,
      inventory: data.inventory
    };

    return data;
  }

  window.addEventListener("beforeunload", () => {
    const data = gatherSheetData();

    const form = document.getElementById("autosave-form");
    form.querySelector("[name='name']").value = data.name;
    form.querySelector("[name='className']").value = data.className;
    form.querySelector("[name='level']").value = data.level;
    form.querySelector("#stats-json").value = JSON.stringify(data.stats);

    form.submit();
  });
</script>

