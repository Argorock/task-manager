<h1 class="sheet-title">Character Sheet</h1>

<div class="sheet-container">

  <!-- LEFT COLUMN -->
  <div class="sheet-left">

    <!-- Character Name -->
    <div class="char-name-box">
      <h2><%= character.name %></h2>
      <div class="char-class-level">
        <%= character.class %> — Level <%= character.level %>
      </div>
    </div>

    <!-- Ability Scores -->
    <div class="ability-scores">
      <h3>Ability Scores</h3>

      <% const abilities = ["Strength", "Dexterity", "Constitution", "Intelligence", "Wisdom", "Charisma"]; %>

      <% abilities.forEach(a => { %>
        <div class="ability-box">
          <div class="ability-label"><%= a %></div>
          <div class="ability-score">10</div>
          <div class="ability-mod">+0</div>
        </div>
      <% }) %>
    </div>

    <!-- Skills -->
    <div class="skills-section">
      <h3>Skills</h3>

      <% 
        const baseSkillNames = {
          acrobatics: "Acrobatatics (Dex)",
          animalHandling: "Animal Handling (Wis)",
          arcana: "Arcana (Int)",
          athletics: "Athletics (Str)",
          deception: "Deception (Cha)",
          history: "History (Int)",
          insight: "Insight (Wis)",
          intimidation: "Intimidation (Cha)",
          investigation: "Investigation (Int)",
          medicine: "Medicine (Wis)",
          nature: "Nature (Int)",
          perception: "Perception (Wis)",
          performance: "Performance (Cha)",
          persuasion: "Persuasion (Cha)",
          religion: "Religion (Int)",
          sleightOfHand: "Sleight of Hand (Dex)",
          stealth: "Stealth (Dex)",
          survival: "Survival (Wis)"
        };
      %>

      <ul class="skills-list">

        <% for (const baseSkill in character.skills) { 
             const skill = character.skills[baseSkill];
             if (!skill || typeof skill !== "object") continue;
        %>

          <!-- BASE SKILL -->
          <li class="skill-base">
            <div class="skill-header">
              <span class="skill-name"><%= baseSkillNames[baseSkill] || baseSkill %></span>
              <span class="skill-meta">
                <%= skill.tier %> — <%= skill.xp %> XP — <%= skill.points %> SP
              </span>
            </div>

            <!-- SUB-SKILLS (wrapped inside <li> to avoid invalid HTML) -->
            <% if (skill.subs && Object.keys(skill.subs).length > 0) { %>
              <ul class="subskill-list">
                <% for (const sub in skill.subs) { 
                     const subSkill = skill.subs[sub];
                %>
                  <li class="subskill-item">
                    <span class="subskill-name"><%= sub %></span>
                    <span class="subskill-meta">
                      <%= subSkill.tier %> — <%= subSkill.xp %> XP — <%= subSkill.points %> SP
                    </span>
                  </li>
                <% } %>
              </ul>
            <% } %>

          </li>

        <% } %>

      </ul>
    </div>

  </div>

  <!-- RIGHT COLUMN -->
  <div class="sheet-right">

    <!-- Combat Stats -->
    <div class="combat-stats">
      <div class="combat-box">
        <div class="combat-label">Armor Class</div>
        <div class="combat-value">12</div>
      </div>

      <div class="combat-box">
        <div class="combat-label">Initiative</div>
        <div class="combat-value">+2</div>
      </div>

      <div class="combat-box">
        <div class="combat-label">Speed</div>
        <div class="combat-value">30 ft</div>
      </div>

      <div class="combat-box">
        <div class="combat-label">Hit Points</div>
        <div class="combat-value">10</div>
      </div>
    </div>

    <!-- XP -->
    <div class="xp-section">
      <h3>Experience Points</h3>
      <div class="xp-bar">
        <div class="xp-fill" style="<%= 'width:' + character.xp + '%;' %>"></div>
      </div>
      <div class="xp-value"><%= character.xp %> XP</div>
    </div>

    <!-- Traits -->
    <div class="traits-section">
      <h3>Personality Traits</h3>
      <div class="traits-box">Calm, disciplined, focused.</div>
            <h3>Ideals</h3>
      <div class="traits-box">Growth through challenge.</div>

      <h3>Bonds</h3>
      <div class="traits-box">Committed to self‑improvement.</div>

      <h3>Flaws</h3>
      <div class="traits-box">Perfectionist tendencies.</div>
    </div> <!-- END traits-section -->

  </div> <!-- END sheet-right -->

</div> <!-- END sheet-container -->
