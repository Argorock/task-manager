<h1>Quests</h1>

<a class="btn" href="/quests/create">Create New Quest</a>

<div>
  <% quests.forEach(q => { %>
    <div class="quest-card">
      <div class="quest-title">
        <a href="/quests/<%= q.id %>"><%= q.title %></a>
      </div>
      <div class="quest-meta">
        Difficulty: <%= q.difficulty %> — <%= q.xp %> XP
      </div>
    </div>
  <% }) %>
</div>
